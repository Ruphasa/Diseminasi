---
import Layout from '../layouts/Layout.astro';
import Slide from '../components/Slide.astro';
import GlassCard from '../components/GlassCard.astro';
---

<Layout title="Transformasi Digital Manajemen Aset - PT INKA">
  <main id="presentation-root" class="relative w-full h-screen bg-transparent text-inka-black overflow-hidden">
    
    <!-- SLIDE 1: Title Slide (Proportional Logos, Bottom-Left Dark Glass Card) -->
    <Slide id="slide-1" isActive={true} align="custom" bgImage="/assets/img/slide-1.jpeg" overlayOpacity="bg-black/50">
      <div class="h-full w-full flex flex-col justify-between p-6 md:p-12">
        <!-- Top Logos (Much Larger & Proportional) -->
        <div class="flex justify-between items-center w-full anim-slide-up opacity-0">
          <div class="bg-white/90 p-3 md:p-4 rounded-2xl shadow-xl backdrop-blur-md border border-white/40">
            <img src="/assets/img/logo inka full.png" alt="PT INKA" class="h-14 md:h-20 object-contain" />
          </div>
          <div class="bg-white/90 p-3 md:p-4 rounded-2xl shadow-xl backdrop-blur-md border border-white/40">
            <img src="/assets/img/LOGOSIPETA.png" alt="SIPETA" class="h-12 md:h-16 object-contain" />
          </div>
        </div>

        <!-- Asymmetric Bottom-Left Card -->
        <div class="max-w-3xl mb-4 md:mb-8 anim-slide-up opacity-0 stagger-1">
          <GlassCard intensity="dark" className="p-8 md:p-12 shadow-2xl border-l-8 border-l-inka-red">
            <span class="inline-block px-4 py-1.5 bg-inka-red text-white text-xs md:text-sm font-bold tracking-wider rounded-full mb-4 uppercase shadow-md shadow-inka-red/30">
              Laporan Diseminasi Magang
            </span>
            <h1 class="text-2xl md:text-4xl font-extrabold tracking-tight text-white mb-4 leading-tight uppercase">
              Pengembangan Assets Tracker dan Digital Twins untuk Pengelolaan Aset Produksi Serta Maintenance pada Aplikasi SIPETA
            </h1>
            <h2 class="text-xl md:text-2xl text-inka-red font-semibold mb-6">
              PT INKA (Persero)
            </h2>
            <div class="flex items-center gap-4 text-gray-300 text-sm md:text-base border-t border-white/10 pt-4 font-medium">
              <span class="text-white">Rizqi Fauzan</span>
              <span>•</span>
              <span>22 Des 2025 - 30 Jun 2026</span>
            </div>
          </GlassCard>
        </div>
      </div>
    </Slide>

    <!-- SLIDE 2: PT INKA Intro (Soft Rounded Glass Card) -->
    <Slide id="slide-2" align="custom" bgImage="/assets/img/slide-2.png" overlayOpacity="bg-black/40">
      <div class="h-full w-full flex items-center justify-center p-6">
        <div class="w-full max-w-5xl anim-scale-in opacity-0">
          <GlassCard intensity="dark" className="p-12 md:p-20 text-center border-2 border-inka-red/60 rounded-3xl shadow-2xl">
            <h2 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight">
              PT INKA (Persero)
            </h2>
            <p class="text-2xl md:text-3xl text-gray-200 font-light max-w-3xl mx-auto leading-relaxed">
              Mendukung operasional manufaktur kereta api terintegrasi terbesar di <span class="text-inka-red font-bold">Asia Tenggara</span>.
            </p>
          </GlassCard>
        </div>
      </div>
    </Slide>

    <!-- SLIDE 3: Before / After (Asymmetric Staggered Split Screen) -->
    <Slide id="slide-3" align="custom">
      <div class="h-full w-full flex flex-col justify-center max-w-7xl mx-auto p-6">
        <span class="text-sm font-bold text-inka-red uppercase tracking-widest mb-2 block anim-slide-up opacity-0">Bagian Satu - Tantangan & Solusi</span>
        <h2 class="text-4xl font-extrabold text-inka-black mb-8 anim-slide-up opacity-0 stagger-1">Perubahan Paradigma</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
          <div class="md:col-span-5 md:-translate-y-4">
            <GlassCard intensity="light" className="p-8 border-l-4 border-l-gray-400 anim-fade-left opacity-0 shadow-lg">
              <div class="w-12 h-12 rounded-2xl bg-gray-200/80 flex items-center justify-center text-gray-600 font-bold mb-6 text-xl">
                ✕
              </div>
              <h3 class="text-2xl font-bold text-gray-700 mb-3">Masalah di Lapangan</h3>
              <p class="text-lg text-inka-gray leading-relaxed">
                Pemantauan manual berbasis kertas dan spreadsheet kehilangan konteks visual serta lokasi tata letak aset secara real-time.
              </p>
            </GlassCard>
          </div>

          <div class="md:col-span-7 md:translate-y-4">
            <GlassCard intensity="heavy" className="p-10 border-l-4 border-l-inka-red anim-fade-right opacity-0 stagger-2 shadow-2xl">
              <div class="w-12 h-12 rounded-2xl bg-inka-red text-white flex items-center justify-center font-bold mb-6 text-xl shadow-lg shadow-inka-red/40">
                ✓
              </div>
              <h3 class="text-3xl font-extrabold text-inka-black mb-4">Solusi Digital SIPETA</h3>
              <p class="text-xl text-gray-800 leading-relaxed mb-6 font-medium">
                Pemetaan presisi 2D/3D interaktif dan monitoring lokasi aset secara real-time layaknya dunia nyata.
              </p>
              <div class="inline-flex items-center gap-2 text-inka-red font-bold text-sm uppercase tracking-wider">
                <span class="w-2 h-2 rounded-full bg-inka-red animate-ping"></span> Real-Time Tracking Active
              </div>
            </GlassCard>
          </div>
        </div>
      </div>
    </Slide>

    <!-- SLIDE 4: Assets Tracker (Spacious Layered Experience: Top-Right Mockup + Bottom-Left GlassCard) -->
    <Slide id="slide-4" align="custom">
      <div class="h-full w-full flex items-center justify-center max-w-7xl mx-auto p-4 md:p-8">
        <div class="relative w-full h-[560px] flex flex-col md:block">
          
          <!-- Mockup Window (Top-Right: 58% Width, Top-0, Right-0) -->
          <div class="md:absolute md:top-0 md:right-0 md:w-[58%] z-10 rounded-3xl overflow-hidden shadow-2xl border border-gray-300 bg-slate-900 anim-fade-right opacity-0 stagger-1">
            <div class="flex items-center justify-between border-b border-white/10 px-5 py-3 bg-slate-950">
              <div class="flex gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <span class="text-xs text-gray-400 font-mono font-semibold">Assets Tracker Interface</span>
            </div>
            
            <div class="relative h-[360px] md:h-[400px] bg-slate-900 overflow-hidden">
              <img src="/assets/img/mockup-assets-tracker.png" alt="Assets Tracker UI" class="w-full h-full object-cover object-top" />
            </div>
          </div>

          <!-- Glass Card Features (Bottom-Left: 48% Width, Bottom-0, Left-0) -->
          <div class="md:absolute md:bottom-0 md:left-0 md:w-[48%] z-20 mt-6 md:mt-0 anim-fade-left opacity-0">
            <GlassCard intensity="heavy" className="p-8 md:p-10 border-t-4 border-t-inka-red shadow-2xl backdrop-blur-2xl">
              <span class="text-xs font-bold text-inka-red uppercase tracking-wider mb-2 block">Fitur Unggulan 01</span>
              <h3 class="text-3xl md:text-4xl font-extrabold text-inka-black mb-3">Assets Tracker</h3>
              <p class="text-base text-inka-gray mb-6 font-medium">Pelacakan posisi dan kondisi aset secara presisi.</p>
              
              <ul class="space-y-4">
                <li class="flex items-start gap-4 anim-slide-up opacity-0 stagger-3">
                  <span class="w-6 h-6 rounded-full bg-inka-red/10 text-inka-red flex items-center justify-center font-bold text-sm mt-1">✓</span>
                  <div>
                    <h4 class="font-bold text-inka-black">Integrasi Koordinat GPS</h4>
                    <p class="text-sm text-gray-600">Sinkronisasi data posisi fisik aset di seluruh area pabrik.</p>
                  </div>
                </li>
                <li class="flex items-start gap-4 anim-slide-up opacity-0 stagger-4">
                  <span class="w-6 h-6 rounded-full bg-inka-red/10 text-inka-red flex items-center justify-center font-bold text-sm mt-1">✓</span>
                  <div>
                    <h4 class="font-bold text-inka-black">Sinkronisasi Real-Time WebSocket</h4>
                    <p class="text-sm text-gray-600">Update status tanpa perlu reload halaman.</p>
                  </div>
                </li>
              </ul>
            </GlassCard>
          </div>

        </div>
      </div>
    </Slide>

    <!-- SLIDE 5: Digital Twins (50/50 Split Vertical with Large Legible Typography) -->
    <Slide id="slide-5" align="custom" bgImage="/assets/img/slide-3.jpeg" overlayOpacity="bg-black/40">
      <div class="h-full w-full flex flex-col justify-between max-w-7xl mx-auto p-6 md:p-10 gap-6">
        
        <!-- Top Real Mockup Image -->
        <div class="w-full h-[48%] rounded-3xl overflow-hidden border border-white/20 shadow-2xl anim-slide-up opacity-0 relative bg-slate-900/90">
          <img src="/assets/img/mockup-digital-twins.png" alt="Digital Twins UI" class="w-full h-full object-cover object-top" />
          <div class="absolute bottom-3 left-4 px-3.5 py-1.5 bg-black/70 backdrop-blur-md text-white text-xs font-mono rounded-full border border-white/20 font-bold">
            Digital Twins Floor Plan View
          </div>
        </div>

        <!-- Bottom Glass Panel (Large Typography) -->
        <div class="w-full anim-slide-up opacity-0 stagger-2">
          <GlassCard intensity="dark" className="p-8 md:p-10 border-t-4 border-t-inka-red rounded-3xl shadow-2xl">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
              <div class="md:col-span-5">
                <span class="text-sm font-extrabold text-inka-red uppercase tracking-wider mb-2 block">Fitur Unggulan 02</span>
                <h3 class="text-4xl md:text-5xl font-black text-white mb-2">Digital Twins</h3>
                <p class="text-lg md:text-xl text-gray-200 font-medium">Visualisasi 3D/2D Tata Letak Layout Aset Pabrik.</p>
              </div>
              
              <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="p-6 rounded-2xl bg-white/10 border border-white/15 backdrop-blur-md">
                  <div class="text-inka-red font-bold text-lg md:text-xl mb-2">⚡ Auto Layout Strategy</div>
                  <p class="text-sm md:text-base text-gray-100 font-medium leading-relaxed">Algoritma penempatan otomatis untuk efisiensi ruang produksi.</p>
                </div>
                <div class="p-6 rounded-2xl bg-white/10 border border-white/15 backdrop-blur-md">
                  <div class="text-inka-red font-bold text-lg md:text-xl mb-2">🎯 Representasi 1:1</div>
                  <p class="text-sm md:text-base text-gray-100 font-medium leading-relaxed">Replika digital presisi sesuai ukuran & koordinat dunia nyata.</p>
                </div>
              </div>
            </div>
          </GlassCard>
        </div>

      </div>
    </Slide>

    <!-- SLIDE 6: Timeline (Real Native Brand SVGs) -->
    <Slide id="slide-6" align="custom">
      <div class="h-full w-full flex flex-col justify-center max-w-7xl mx-auto p-6">
        <div class="flex justify-between items-end mb-12">
          <div>
            <span class="text-xs font-bold text-inka-red uppercase tracking-widest mb-1 block anim-slide-up opacity-0">Bagian Dua - Optimasi & Otomatisasi (Carryover Projects)</span>
            <h3 class="text-4xl md:text-5xl font-black text-inka-black anim-slide-up opacity-0 stagger-1">Skalabilitas Operasional</h3>
          </div>
          <span class="text-sm font-mono text-gray-400 hidden md:block">04 Enhancements</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          
          <!-- Card 1: WhatsApp -->
          <div class="anim-slide-up opacity-0 stagger-1">
            <GlassCard intensity="heavy" className="p-6 border-t-4 border-t-inka-red shadow-xl hover:-translate-y-2 transition-transform duration-300">
              <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center mb-4">
                <svg class="w-7 h-7 text-green-500 fill-current" viewBox="0 0 24 24">
                  <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981z"/>
                </svg>
              </div>
              <div class="text-xs font-mono text-inka-red font-bold mb-1">STEP 01</div>
              <h4 class="text-xl font-extrabold text-inka-black mb-2">Notifikasi WA</h4>
              <p class="text-sm text-gray-600 leading-relaxed font-medium">Eskalasi otomatis berdasar SLA.</p>
            </GlassCard>
          </div>

          <!-- Card 2: Looker Studio -->
          <div class="anim-slide-up opacity-0 stagger-2 md:translate-y-4">
            <GlassCard intensity="heavy" className="p-6 border-t-4 border-t-inka-red shadow-xl hover:-translate-y-2 transition-transform duration-300">
              <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center mb-4">
                <svg class="w-7 h-7 text-blue-600 fill-current" viewBox="0 0 24 24">
                  <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
                </svg>
              </div>
              <div class="text-xs font-mono text-inka-red font-bold mb-1">STEP 02</div>
              <h4 class="text-xl font-extrabold text-inka-black mb-2">Looker Studio</h4>
              <p class="text-sm text-gray-600 leading-relaxed font-medium">Row-Level upsert & Sinkronisasi.</p>
            </GlassCard>
          </div>

          <!-- Card 3: Google Sheets -->
          <div class="anim-slide-up opacity-0 stagger-3 md:translate-y-8">
            <GlassCard intensity="heavy" className="p-6 border-t-4 border-t-inka-red shadow-xl hover:-translate-y-2 transition-transform duration-300">
              <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center mb-4">
                <svg class="w-7 h-7 text-emerald-600 fill-current" viewBox="0 0 24 24">
                  <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 3v3h-7V6h7zm-8 0v3H5V6h6zm-6 5h6v3H5v-3zm0 5h6v3H5v-3zm14 3h-7v-3h7v3zm0-5h-7v-3h7v3z"/>
                </svg>
              </div>
              <div class="text-xs font-mono text-inka-red font-bold mb-1">STEP 03</div>
              <h4 class="text-xl font-extrabold text-inka-black mb-2">Opname & Sheets</h4>
              <p class="text-sm text-gray-600 leading-relaxed font-medium">Filter soft-delete & normalisasi.</p>
            </GlassCard>
          </div>

          <!-- Card 4: Infrastructure / Storage -->
          <div class="anim-slide-up opacity-0 stagger-4 md:translate-y-12">
            <GlassCard intensity="heavy" className="p-6 border-t-4 border-t-inka-red shadow-xl hover:-translate-y-2 transition-transform duration-300">
              <div class="w-12 h-12 rounded-2xl bg-purple-500/10 flex items-center justify-center mb-4">
                <svg class="w-7 h-7 text-purple-600 fill-current" viewBox="0 0 24 24">
                  <path d="M4 6h16v4H4V6zm0 6h16v4H4v-4zm0 6h16v4H4v-4z"/>
                </svg>
              </div>
              <div class="text-xs font-mono text-inka-red font-bold mb-1">STEP 04</div>
              <h4 class="text-xl font-extrabold text-inka-black mb-2">Storage Infra</h4>
              <p class="text-sm text-gray-600 leading-relaxed font-medium">Migrasi ke internal auto-create.</p>
            </GlassCard>
          </div>

        </div>
      </div>
    </Slide>

    <!-- SLIDE 7: UI/UX & QoL (Enlarged Cards and Typography) -->
    <Slide id="slide-7" align="custom">
      <div class="h-full w-full flex flex-col justify-center max-w-7xl mx-auto p-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center">
          
          <div class="md:col-span-5 anim-fade-left opacity-0">
            <span class="text-xs font-bold text-inka-red uppercase tracking-widest mb-2 block">Bagian Tiga - Menyempurnakan Pengalaman</span>
            <h3 class="text-5xl md:text-6xl font-black text-inka-black leading-tight mb-6">
              Detail Kecil,<br/>Dampak Besar
            </h3>
            <p class="text-xl text-inka-gray font-medium leading-relaxed">
              Penyempurnaan pada fleksibilitas pengguna dan ketahanan arsitektur backend.
            </p>
          </div>

          <div class="md:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
            {[
              { title: "Manajemen Sub-Aset", desc: "Upload terpisah & Autofill hirarki data secara otomatis." },
              { title: "Bypass Approval", desc: "Akses khusus SM & GM dengan robust permission checking." },
              { title: "Sinkronisasi Pintar", desc: "Auto-sync PIC & rute dinamis QR Code." },
              { title: "Optimasi Sistem", desc: "Dukungan PHP 7+ & PDF Header BAO terstandar." }
            ].map((box, idx) => (
              <div class="anim-scale-in opacity-0" style={`animation-delay: ${0.15 * (idx + 1)}s`}>
                <GlassCard intensity="heavy" className="p-8 border-l-4 border-l-inka-red shadow-xl hover:shadow-2xl transition-shadow">
                  <h4 class="text-xl font-bold text-inka-black mb-3">{box.title}</h4>
                  <p class="text-sm text-gray-600 font-medium leading-relaxed">{box.desc}</p>
                </GlassCard>
              </div>
            ))}
          </div>

        </div>
      </div>
    </Slide>

    <!-- SLIDE 8: Penutup Intro (HD Image 4 Background) -->
    <Slide id="slide-8" align="custom" bgImage="/assets/img/slide-4.png" overlayOpacity="bg-black/50">
      <div class="h-full w-full flex items-center justify-center p-6">
        <div class="w-full max-w-5xl anim-scale-in opacity-0">
          <GlassCard intensity="dark" className="p-14 text-center border-b-4 border-b-inka-red shadow-2xl">
            <p class="text-lg text-gray-300 uppercase tracking-widest font-bold mb-4">Penutup</p>
            <h2 class="text-5xl md:text-7xl font-extrabold text-white leading-tight">
              Pelajaran & Implikasi Teknis Bagi Pengembang
            </h2>
          </GlassCard>
        </div>
      </div>
    </Slide>

    <!-- SLIDE 9: Quote (Fixed Blank Screen Bug with Wrapper Separation) -->
    <Slide id="slide-9" align="custom">
      <div class="h-full w-full flex items-center justify-center p-6">
        <div class="w-full max-w-5xl anim-scale-in opacity-0">
          <GlassCard 
            intensity="heavy" 
            glow={true}
            className="p-16 md:p-20 text-center relative border border-inka-red/30 shadow-2xl"
          >
            <div class="text-6xl text-inka-red font-serif mb-4">“</div>
            <h2 class="text-4xl md:text-6xl font-black italic text-inka-black mb-8 leading-snug">
              Code is easy.<br/><span class="text-inka-red">Understanding the problem</span> is hard.
            </h2>
            <div class="w-24 h-1.5 bg-inka-red mx-auto mb-6 anim-grow-h"></div>
            <p class="text-xl md:text-2xl text-gray-700 font-medium">
              Fokus pada pemahaman konteks bisnis sebelum mengeksekusi kode.
            </p>
          </GlassCard>
        </div>
      </div>
    </Slide>

    <!-- SLIDE 10: Thank You (Clean Asymmetric Left Title & Subtle Bottom Right Watermark) -->
    <Slide id="slide-10" align="custom">
      <div class="h-full w-full flex flex-col justify-between p-12 md:p-20 max-w-7xl mx-auto relative">
        <div class="my-auto max-w-2xl">
          <span class="px-4 py-1.5 bg-inka-red text-white text-xs font-bold uppercase tracking-wider rounded-full mb-6 inline-block anim-slide-up opacity-0 shadow-md">
            Selesai
          </span>
          <h1 class="text-7xl md:text-9xl font-black text-inka-black tracking-tight mb-4 anim-fade-left opacity-0 stagger-1">
            Terima<br/><span class="text-inka-red">Kasih</span>
          </h1>
          <p class="text-3xl text-gray-700 font-semibold anim-slide-up opacity-0 stagger-2">
            Ada Pertanyaan?
          </p>
        </div>

        <!-- Subtle Bottom Right Watermark -->
        <div class="absolute bottom-8 right-12 flex items-center gap-3 opacity-40 anim-fade-right opacity-0 stagger-3">
          <img src="/assets/img/LOGOSIPETA.png" alt="SIPETA" class="h-8 object-contain" />
          <span class="text-xs font-mono font-bold text-gray-600">SIPETA © 2026</span>
        </div>
      </div>
    </Slide>

    <!-- Navigation Controls -->
    <div class="absolute bottom-8 right-8 z-50 flex items-center gap-4">
      <button id="btn-prev" class="w-12 h-12 rounded-full bg-white/50 backdrop-blur-md flex items-center justify-center border border-white/60 text-inka-black shadow-lg cursor-pointer hover:bg-white/80 transition-all hover:scale-105 active:scale-95">
        ←
      </button>
      <button id="btn-next" class="w-12 h-12 rounded-full bg-white/50 backdrop-blur-md flex items-center justify-center border border-white/60 text-inka-black shadow-lg cursor-pointer hover:bg-white/80 transition-all hover:scale-105 active:scale-95">
        →
      </button>
    </div>
    
    <div class="absolute bottom-8 left-8 z-50 text-inka-gray font-mono text-sm font-bold bg-white/40 px-4 py-2 rounded-full backdrop-blur-md border border-white/60 shadow-sm">
      Slide <span id="current-slide">1</span> / 10
    </div>
  </main>
</Layout>

<script>
  let currentSlideIndex = 1;
  const totalSlides = 10;

  function updateSlides() {
    document.querySelectorAll('.slide').forEach((slide, index) => {
      const slideNum = index + 1;
      if (slideNum === currentSlideIndex) {
        slide.classList.remove('opacity-0', 'scale-95', 'z-0', 'pointer-events-none');
        slide.classList.add('slide-active', 'opacity-100', 'scale-100', 'z-10', 'pointer-events-auto');
      } else {
        slide.classList.remove('slide-active', 'opacity-100', 'scale-100', 'z-10', 'pointer-events-auto');
        slide.classList.add('opacity-0', 'scale-95', 'z-0', 'pointer-events-none');
      }
    });

    const currentSlideEl = document.getElementById('current-slide');
    if (currentSlideEl) currentSlideEl.innerText = currentSlideIndex.toString();
  }

  function nextSlide() {
    if (currentSlideIndex < totalSlides) {
      currentSlideIndex++;
      updateSlides();
    }
  }

  function prevSlide() {
    if (currentSlideIndex > 1) {
      currentSlideIndex--;
      updateSlides();
    }
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === 'Space') {
      nextSlide();
    } else if (e.key === 'ArrowLeft') {
      prevSlide();
    }
  });

  document.getElementById('btn-next')?.addEventListener('click', nextSlide);
  document.getElementById('btn-prev')?.addEventListener('click', prevSlide);

  updateSlides();
</script>
