---
interface Props {
  id: string;
  isActive?: boolean;
  align?: 'center' | 'left' | 'right' | 'custom';
  bgImage?: string;
  overlayOpacity?: string;
}

const { 
  id, 
  isActive = false, 
  align = 'center', 
  bgImage,
  overlayOpacity = 'bg-black/50'
} = Astro.props;

const alignClass = {
  center: 'items-center justify-center text-center',
  left: 'items-start justify-center text-left',
  right: 'items-end justify-center text-right',
  custom: '' // for complex layouts handled inside slot
}[align];
---

<section 
  id={id}
  class={`slide absolute inset-0 flex flex-col p-8 md:p-16 transition-all duration-700 ease-in-out ${alignClass} ${isActive ? 'slide-active opacity-100 scale-100 z-10 pointer-events-auto' : 'opacity-0 scale-95 z-0 pointer-events-none'}`}
>
  {bgImage && (
    <div class="absolute inset-0 z-[-1] overflow-hidden">
      <img 
        src={bgImage} 
        alt="Slide Background"
        class="w-full h-full object-cover anim-kenburns"
      />
      <div class={`absolute inset-0 ${overlayOpacity}`}></div>
    </div>
  )}
  <div class="relative z-10 w-full h-full flex flex-col">
    <slot />
  </div>
</section>
